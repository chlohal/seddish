#!/bin/sh

# SUSv3 compliant sed tests.
# Copyright 2005 by Rob Landley <rob@landley.net>
# Licensed under GPLv2, see file LICENSE in this source tree.

. ./adapt_testing.sh

# testing "description" "commands" "result" "infile" "stdin"

# Corner cases
testing "sed no files (stdin)" 'sed ""' "hello\n" "" "hello\n"
testing "sed explicit stdin" 'sed "" -' "hello\n" "" "hello\n"
testing "sed handles empty lines" "sed 's/\$/@/'" "@\n" "" "\n"
testing "sed stdin twice" 'sed "" - -' "hello" "" "hello"

# Trailing EOF.
#	Match $, at end of each file or all files?

# -e corner cases
#	without -e
#	multiple -e
#		interact with a
#	-eee arg1 arg2 arg3
# -f corner cases
#	-e -f -e
# -n corner cases
#	no newline at EOF?
# -r corner cases
#	Just make sure it works.
# -i corner cases:
#	sed -i -
#	permissions
#	-i on a symlink
#	on a directory
#       With $ last-line test
# Continue with \
#       End of script with trailing \

# command list
testing "sed accepts blanks before command" "sed '1 d'" "" "" ""
testing "sed accepts newlines in -e" "sed 'i\
1
a\
3'" "1\n2\n3\n" "" "2\n"

# substitutions
testing "sed with empty match" "sed 's/z*//g'" "string\n" "" "string\n"
testing "sed s//p" "sed 's/foo/bar/p; s/bar/baz/p'" "bar\nbaz\nbaz\n" \
	"" "foo\n"
testing "sed s//g (exhaustive)" "sed 's/[[:space:]]*/,/g'" ",1,2,3,4,5,\n" \
	"" "12345\n"
testing "sed s arbitrary delimiter" "sed 's woo boing '" "boing\n" "" "woo\n"
testing "sed s chains" "sed 's/foo/bar/; s/bar/baz/'" "baz\n" "" "foo\n"
testing "sed s chains2" "sed 's/foo/bar/; s/baz/nee/'" "bar\n" "" "foo\n"
testing "sed s [delimiter]" "sed 's@[@]@@'" "onetwo" "" "one@two"
testing "sed s with \\t (GNU ext)" "sed 's/\t/ /'" "one two" "" "one\ttwo"

# branch
testing "sed b (branch)" "sed 'b one;p;: one'" "foo\n" "" "foo\n"
testing "sed b (branch with no label jumps to end)" "sed 'b;p'" \
	"foo\n" "" "foo\n"

# test and branch
testing "sed t (test/branch)" "sed 's/a/1/;t one;p;: one;p'" \
	"1\n1\nb\nb\nb\nc\nc\nc\n" "" "a\nb\nc\n"
testing "sed t (test/branch clears test bit)" "sed 's/a/b/;:loop;t loop'" \
	"b\nb\nc\n" "" "a\nb\nc\n"
testing "sed T (!test/branch)" "sed 's/a/1/;T notone;p;: notone;p'" \
	"1\n1\n1\nb\nb\nc\nc\n" "" "a\nb\nc\n"

testing "sed n (flushes pattern space, terminates early)" "sed 'n;p'" \
	"a\nb\nb\nc\n" "" "a\nb\nc\n"

# non-GNU sed: N does _not_ flush pattern space, therefore c is eaten @ script end
# GNU sed: N flushes pattern space, therefore c is printed too @ script end
testing "sed N (flushes pattern space (GNU behavior))" "sed 'N;p'" \
	"a\nb\na\nb\nc\n" "" "a\nb\nc\n"

testing "sed N test2" "sed ':a;N;s/\n/ /;ta'" \
	"a b c\n" "" "a\nb\nc\n"

testing "sed N test3" "sed 'N;s/\n/ /'" \
	"a b\nc\n" "" "a\nb\nc\n"

testing "sed address match newline" 'sed "/b/N;/b\\nc/i woo"' \
	"a\nwoo\nb\nc\nd\n" "" "a\nb\nc\nd\n"

# Multiple lines in pattern space
testing "sed N (stops at end of input) and P (prints to first newline only)" \
	"sed 'N;P;p'" "a\na\nb\na\nb\nc\n" "" "a\nb\nc\n"

# Hold space
testing "sed G (append hold space to pattern space)" 'sed G' "a\n\nb\n\nc\n\n" \
	"" "a\nb\nc\n"
#testing "sed g/G (swap/append hold and patter space)"
#testing "sed g (swap hold/pattern space)"

testing "sed d ends script iteration" \
	"sed '/ook/d;s/ook/ping/p;i woot'" "" "" "ook\n"

# Multiple files, with varying newlines and NUL bytes
test x"$SKIP_KNOWN_BUGS" = x"" && {
testing "sed embedded NUL" "sed 's/woo/bang/'" "\0bang\0woo\0" "" \
	"\0woo\0woo\0"
}
testing "sed embedded NUL g" "sed 's/woo/bang/g'" "bang\0bang\0" "" \
	"woo\0woo\0"

# sed has funky behavior with newlines at the end of file.  Test lots of
# corner cases with the optional newline appending behavior.

testing "sed append autoinserts newline" "sed '/woot/a woo' -" \
	"woot\nwoo\n" "" "woot"
testing "sed append autoinserts newline 2" "sed '/oot/a woo'" \
	"boot\nwoo\nwoot\nwoo\n" "" "boot\nwoot"
testing "sed append autoinserts newline 3" "sed '/oot/a woo'" \
	"boot\nwoo\n" "" "boot"
testing "sed insert doesn't autoinsert newline" "sed '/woot/i woo'" \
	"woo\nwoot" "" "woot"
testing "sed print autoinsert newlines" "sed 'p'" "one\none" "" "one"
testing "sed print autoinsert newlines 'two files'" "sed 'p'" \
	"one\none\ntwo\ntwo" "" "one\ntwo"
testing "sed trailing NUL" \
	"sed 's/i/z/'" \
	"a\0b\0\nc" "" "a\0b\0\nc"
testing "sed escaped newline in command" \
	"sed 's/a/z\\
z/'" \
	"z\nz" "" "a"

# Test end-of-file matching behavior

testing "sed match EOF" "sed '"'$p'"'" "hello\nthere\nthere" "" \
	"hello\nthere"

testing "sed backref from empty s uses range regex" \
	"sed '/woot/s//eep \0 eep/'" "eep woot eep" "" "woot"

testing "sed backref from empty s uses range regex with newline" \
	"sed '/woot/s//eep \0 eep/'" "eep woot eep\n" "" "woot\n"

testing "sed s/xxx/[/" "sed 's/xxx/[/'" "[\n" "" "xxx\n"


# testing "description" "commands" "result" "infile" "stdin"

testing "sed n command must reset 'substituted' bit" \
	"sed 's/1/x/;T;n;: next;s/3/y/;t quit;n;b next;: quit;q'" \
	"0\nx\n2\ny\n" "" "0\n1\n2\n3\n"

testing "sed d does not break n,m matching" \
	"sed '1d;1,3p;4d'" \
	"second\nsecond\nthird\nthird\n" "" "first\nsecond\nthird\nfourth\n"

testing "sed d does not break n,regex matching" \
	"sed '1d;1,/hir/p; 4d'" \
	"second\nsecond\nthird\nthird\n" "" "first\nsecond\nthird\nfourth\n"

# Regex means: "match / at BOL or nothing, then one or more not-slashes".
# The bug was that second slash in /usr/lib was treated as "at BOL" too.
testing "sed beginning (^) matches only once" \
	"sed 's,\(^/\|\)[^/][^/]*,>\0<,g'" \
	">/usr</>lib<\n" "" \
	"/usr/lib\n"

testing "sed c" \
	"sed 'crepl'" \
	"repl\nrepl\n" "" \
	"first\nsecond\n"

testing "sed nested {}s" \
	"sed '/asd/ { p; /s/ { s/s/c/ }; p; q }'" \
	"qwe\nasd\nacd\nacd\n" "" \
	"qwe\nasd\nzxc\n"

testing "sed a cmd understands \\n,\\t,\\r" \
	"sed '/1/a\\\\t\\rzero\\none\\\\ntwo\\\\\\nthree'" \
"\
line1
\t\rzero
one\\\\ntwo\\
three
" "" "line1\n"

testing "sed i cmd understands \\n,\\t,\\r" \
	"sed '/1/i\\\\t\\rzero\\none\\\\ntwo\\\\\\nthree'" \
"\
\t\rzero
one\\\\ntwo\\
three
line1
" "" "line1\n"

# first three lines are deleted; 4th line is matched and printed by "2,3" and by "4" ranges
testing "sed with N skipping lines past ranges on next cmds" \
	"sed '1{N;N;d};1p;2,3p;3p;4p'" \
	"4\n4\n" "" "1\n2\n3\n4\n"

testing "sed understands \r" \
	"sed 's/r/\r/'" \
	"\rrr\n" "" "rrr\n"

testing "sed zero chars match/replace advances correctly 1" \
	"sed 's/l*/@/g'" \
	"@h@e@o@\n" "" "helllo\n"

testing "sed zero chars match/replace advances correctly 2" \
	"sed 's [^ .]* x g'" \
	"x x.x\n" "" " a.b\n"

testing "sed zero chars match/replace logic must not falsely trigger here 1" \
	"sed 's/a/A/g'" \
	"_AAA1AA\n" "" "_aaa1aa\n"

testing "sed zero chars match/replace logic must not falsely trigger here 2" \
	"sed 's/ *$/_/g'" \
	"qwerty_\n" "" "qwerty\n"

# the pattern here is interpreted as "9+", not as "9\+"
testing "sed special char as s/// delimiter, in pattern" \
	"sed 's+9\++X+'" \
	"X8=17\n" "" "9+8=17\n"

# Matching GNU sed 4.8:
# in replacement string, "\&" remains "\&", not interpreted as "&"
testing "sed special char as s/// delimiter, in replacement 1" \
	"sed 's&9&X\&&'" \
	"X&+8=17\n" "" "9+8=17\n"
# in replacement string, "\1" is interpreted as "1"
testing "sed special char as s/// delimiter, in replacement 2" \
	"sed 's1\(9\)1X\11'" \
	"X1+8=17\n" "" "9+8=17\n"

testing "sed /\$_in_regex/ should not match newlines, only end-of-line" \
	"sed ': testcont; /\\\\$/{ =; N; b testcont }'" \
	"\
this is a regular line
2
line with \\
continuation
more regular lines
5
line with \\
continuation
" \
	"" "\
this is a regular line
line with \\
continuation
more regular lines
line with \\
continuation
"

testing "sed s///NUM test" \
	"sed 's/a/b/2; s/a/c/g'" \
	"cb\n" "" "aa\n"

testing "sed /regex/,N{...} addresses work" \
	"sed /^2/,2{d}" \
	"1\n3\n4\n5\n" \
	"" \
	"1\n2\n3\n4\n5\n"

testing "sed /regex/,+N{...} addresses work" \
	"sed /^2/,+2{d}" \
	"1\n5\n" \
	"" \
	"1\n2\n3\n4\n5\n"

testing "sed /regex/,+N{...} addresses work 2" \
	"sed '/a/,+1 d'" \
	"c\nc\n" \
	"" \
	"a\n1\nc\nc\na\n2\na\n3\n"

testing "sed 's///w FILE'" \
	"sed 's/qwe/ZZZ/wz'; cat z; rm z" \
	"123\nZZZ\nasd\n""ZZZ\n" \
	"" \
	"123\nqwe\nasd\n"

testing "sed uses previous regexp" \
	"sed '/w/p;//q'" \
	"q\nw\nw\n" \
	"" \
	"q\nw\ne\nr\n"

testing "sed ^ OR not^" \
	"sed 's/^a\|b//g'" \
	"ca\n" \
	"" \
	"abca\n"


# testing "description" "commands" "result" "infile" "stdin"

exit $FAILCOUNT
